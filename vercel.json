{
  "rewrites": [
    {
      "source": "/images/:match*",
      "destination": "https://www.toppuer.top/:match*"
    }
  ],
  "headers": [
    {
      "source": "/images/:match*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
